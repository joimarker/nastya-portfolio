# Пароль для входа в /admin
ADMIN_PASSWORD=change-me-to-a-real-password

# Секрет для подписи сессионной cookie — любая длинная случайная строка
SESSION_SECRET=change-me-to-a-random-long-string

# Только для продакшна (Supabase Storage вместо локального диска —
# нужно, чтобы правки из админки и загруженные картинки не пропадали
# при рестарте/деплое). Оставь пустыми для локальной разработки —
# тогда используется data/content.json и public/uploads/ напрямую.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
